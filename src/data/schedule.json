  "programs": {
    "lap-swim": {
      "label": "Lap Swim",
      "description": "Swim laps and practice your strokes during designated lap-swim hours.",
      "ages": "16+",
      "cost": "$7 resident · $8 non-resident",
      "verified": false
    },
    "independent-exercise": {
      "label": "Independent Exercise (Dive Tank)",
      "description": "Self-directed water exercise — water jogging or walking in the dive tank or shallow pool.",
      "ages": "Shallow: all ages · Dive tank: 18+",
      "cost": "$7 resident · $8 non-resident",
      "verified": false
    },
    "family-swim": {
      "label": "Family Swim (Shallow)",
      "description": "Bring little ones of any age to splash around in the shallow pool.",
      "ages": "All ages",
      "cost": "$7 resident · $8 non-resident",
      "verified": false
    },
    "community-swim": {
      "label": "Community Swim",
      "description": "All ages welcome to play in the entire pool during open community hours.",
      "ages": "All ages",
      "cost": "$7 resident · $8 non-resident",
      "verified": false
    },
    "aquatic-masters": {
      "label": "Berkeley Aquatic Masters",
      "description": "Coached workouts for swimmers of all abilities. Requires a premium pass.",
      "ages": "18+",
      "cost": "$8 resident · $10 non-resident (premium)",
      "verified": false
    },
    "senior-exercise": {
      "label": "Senior Exercise",
      "description": "Fun aerobic water exercises with other seniors. Requires a premium pass.",
      "ages": "55+",
      "cost": "$8 resident · $10 non-resident (premium)",
      "verified": false
    },
    "barracudas": {
      "label": "Berkeley Barracudas",
      "description": "Afterschool swim team across four levels. A tryout is required before registration.",
      "ages": "6–18 yrs",
      "cost": "$135 resident · $162 non-resident per 4-week session",
      "verified": false
    },
    "swim-lessons": {
